# Copy to `.env` and fill in. Every lab reads the model from these variables via
# `labgraph.get_chat_model()` — no provider is hardcoded anywhere in the course.
#
# The tests DO NOT need any of this: they run against a deterministic fake model
# and stay green offline. You need these only to run a lab "for real"
# (`uv run python exercises/04-llm-node/graph.py`).

# --- OpenRouter -------------------------------------------------------------
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-...
LLM_MODEL=anthropic/claude-sonnet-4.5

# --- Google Gemini (OpenAI-compatible endpoint) -----------------------------
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=AIza...
# LLM_MODEL=gemini-2.5-flash

# --- Anything else that speaks the OpenAI wire format -----------------------
# LLM_BASE_URL=http://localhost:11434/v1     # Ollama
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1

# Optional knobs (sensible defaults applied when unset)
LLM_TEMPERATURE=0
# LLM_MAX_TOKENS=1024
# LLM_TIMEOUT=60
